<Window x:Class="ClassroomControl.ShutdownReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关机提醒"
        Width="380" SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Border x:Name="RootBorder"
            Background="White"
            CornerRadius="8"
            BorderThickness="1"
            BorderBrush="#E0E0E0">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="2" BlurRadius="16" Opacity="0.2" Direction="270"/>
        </Border.Effect>

        <StackPanel Margin="18,16">
            <!-- 头部：图标 + 标题 + 倒计时 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 警告图标 -->
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                        Background="#FFF3E0" Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="&#xE783;" FontSize="18" FontFamily="Segoe MDL2 Assets"
                               Foreground="#FF5722" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- 标题 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="系统即将关机" FontSize="15" FontWeight="SemiBold" Foreground="#37474F"/>
                    <TextBlock Text="班级电脑控制助手" FontSize="11" Foreground="#90A4AE" Margin="0,1,0,0"/>
                </StackPanel>

                <!-- 倒计时 -->
                <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="6"
                        Padding="10,4" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCountdown" Text="05:00"
                               FontSize="16" FontWeight="Bold" Foreground="#FF5722"
                               FontFamily="Consolas"/>
                </Border>
            </Grid>

            <!-- 描述 -->
            <TextBlock Text="请立即保存您的工作！倒计时结束后将自动执行关机。"
                       FontSize="12" Foreground="#78909C" TextWrapping="Wrap"
                       Margin="0,0,0,16" LineHeight="18"/>

            <!-- 分隔线 -->
            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancelShutdown" Content="取消关机"
                        Click="BtnCancelShutdown_Click" Cursor="Hand"
                        Height="32" Padding="20,0" FontSize="13"
                        Background="Transparent" Foreground="#546E7A"
                        BorderThickness="0" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#F5F5F5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="BtnShutdownNow" Content="立即关机"
                        Click="BtnShutdownNow_Click" Cursor="Hand"
                        Height="32" Padding="20,0" FontSize="13"
                        Background="#FF5722" Foreground="White"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#E64A19"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
